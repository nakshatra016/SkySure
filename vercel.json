{
    "version": 2,
    "functions": {
        "backend/index.js": {
            "maxDuration": 10
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "backend/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/$1"
        }
    ]
}